# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hokimyat

# Database URL (used by app, alembic, celery)
OCR_SERVER_DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/hokimyat

# Redis / Celery
REDIS_URL=redis://redis:6379

# OCR Server
OCR_SERVER_PORT=8000
LOG_LEVEL=INFO

# MinIO / S3 Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_NAME=ocr-server-uploads
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_UPLOADS_BUCKET=ocr-server-uploads

# AI / vLLM
OPENAI_API_BASE_URL=http://vllm:8000/v1
OPENAI_API_KEY=your-api-key
DEFAULT_MODELS=chat-template

# Docling
DOCLING_HOST=http://docling:5001

# PDF extraction limits
MAX_PAGE_RANGE=50
